        {"$GMExtensionFunction":"","%Name":"TaloSDK_players_auth_forgot_password","argCount":0,"args":[1,],"documentation":"/// @description Асинхронный `POST /v1/players/auth/forgot_password` — запрос письма сброса пароля.\r\n/// @param {string} bodyJson JSON с полем `email`.\r\n/// @returns {real} `1` — запрос в очередь; `talo_op` = `\"players_auth_forgot_password\"`.\r\nfunction TaloSDK_players_auth_forgot_password(bodyJson) {\r\n    return 1;\r\n}","externalName":"talo_players_auth_forgot_password","help":"TaloSDK_players_auth_forgot_password(bodyJson)","hidden":false,"kind":4,"name":"TaloSDK_players_auth_forgot_password","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":2,},
        {"$GMExtensionFunction":"","%Name":"TaloSDK_players_auth_reset_password","argCount":0,"args":[1,],"documentation":"/// @description Асинхронный `POST /v1/players/auth/reset_password` — установить новый пароль по коду из письма.\r\n/// @param {string} bodyJson JSON (`code`, `password` — код строкой).\r\n/// @returns {real} `1` — запрос в очередь; `talo_op` = `\"players_auth_reset_password\"`.\r\nfunction TaloSDK_players_auth_reset_password(bodyJson) {\r\n    return 1;\r\n}","externalName":"talo_players_auth_reset_password","help":"TaloSDK_players_auth_reset_password(bodyJson)","hidden":false,"kind":4,"name":"TaloSDK_players_auth_reset_password","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":2,},
        {"$GMExtensionFunction":"","%Name":"TaloSDK_players_auth_toggle_verification","argCount":0,"args":[1,],"documentation":"/// @description Асинхронный `PATCH /v1/players/auth/toggle_verification` — включить/выключить верификацию входа. Нужны заголовки сессии.\r\n/// @param {string} bodyJson JSON (`currentPassword`, `verificationEnabled`, при необходимости `email`).\r\n/// @returns {real} `1` — запрос в очередь; `talo_op` = `\"players_auth_toggle_verification\"`.\r\nfunction TaloSDK_players_auth_toggle_verification(bodyJson) {\r\n    return 1;\r\n}","externalName":"talo_players_auth_toggle_verification","help":"TaloSDK_players_auth_toggle_verification(bodyJson)","hidden":false,"kind":4,"name":"TaloSDK_players_auth_toggle_verification","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":2,},
        {"$GMExtensionFunction":"","%Name":"TaloSDK_players_auth_delete","argCount":0,"args":[1,],"documentation":"/// @description Асинхронный `DELETE /v1/players/auth` — удалить аккаунт (тело с `currentPassword`). Нужны заголовки сессии.\r\n/// @param {string} bodyJson JSON тела запроса.\r\n/// @returns {real} `1` — запрос в очередь; `talo_op` = `\"players_auth_delete\"`.\r\nfunction TaloSDK_players_auth_delete(bodyJson) {\r\n    return 1;\r\n}","externalName":"talo_players_auth_delete","help":"TaloSDK_players_auth_delete(bodyJson)","hidden":false,"kind":4,"name":"TaloSDK_players_auth_delete","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":2,},
        {"$GMExtensionFunction":"","%Name":"TaloSDK_players_auth_migrate","argCount":0,"args":[1,],"documentation":"/// @description Асинхронный `POST /v1/players/auth/migrate` — миграция аккаунта на другой сервис/identifier. Нужны заголовки сессии.\r\n/// @param {string} bodyJson JSON (`currentPassword`, `service`, `identifier`).\r\n/// @returns {real} `1` — запрос в очередь; `talo_op` = `\"players_auth_migrate\"`.\r\nfunction TaloSDK_players_auth_migrate(bodyJson) {\r\n    return 1;\r\n}","externalName":"talo_players_auth_migrate","help":"TaloSDK_players_auth_migrate(bodyJson)","hidden":false,"kind":4,"name":"TaloSDK_players_auth_migrate","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":2,},
        {"$GMExtensionFunction":"","%Name":"TaloSDK_player_groups_get","argCount":0,"args":[1,1,],"documentation":"/// @description Асинхронный `GET /v1/player-groups/:id` — группа игроков и (при настройках) участники с пагинацией.\r\n/// @param {string} groupId UUID группы.\r\n/// @param {string} query Query без `?` (например `membersPage=0`).\r\n/// @returns {real} `1` — запрос в очередь; `talo_op` = `\"player_groups_get\"`.\r\nfunction TaloSDK_player_groups_get(groupId, query) {\r\n    return 1;\r\n}","externalName":"talo_player_groups_get","help":"TaloSDK_player_groups_get(groupId, query)","hidden":false,"kind":4,"name":"TaloSDK_player_groups_get","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":2,},
        {"$GMExtensionFunction":"","%Name":"TaloSDK_players_presence_get","argCount":0,"args":[1,],"documentation":"/// @description Асинхронный `GET /v1/players/presence/:id` — онлайн-статус и custom status игрока по UUID.\r\n/// @param {string} playerId UUID игрока.\r\n/// @returns {real} `1` — запрос в очередь; `talo_op` = `\"players_presence_get\"`.\r\nfunction TaloSDK_players_presence_get(playerId) {\r\n    return 1;\r\n}","externalName":"talo_players_presence_get","help":"TaloSDK_players_presence_get(playerId)","hidden":false,"kind":4,"name":"TaloSDK_players_presence_get","resourceType":"GMExtensionFunction","resourceVersion":"2.0","returnType":2,},
